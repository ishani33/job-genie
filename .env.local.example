# Google Sheets & Drive
# Service account credentials (JSON key file contents as a single line)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Google Sheets IDs (from the sheet URL)
APPLICATIONS_SHEET_ID=your_applications_sheet_id_here
NETWORKING_SHEET_ID=your_networking_sheet_id_here

# Google Drive folder ID for resume storage
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for absolute links in emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
